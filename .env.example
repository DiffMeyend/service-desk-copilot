# QF_Wiz / service-desk-copilot — environment variables
# Copy to .env and fill in values before running

# ── LLM ──────────────────────────────────────────────────────────────────────
# Required for Claude integration (AI triage, evidence interpretation, chat)
ANTHROPIC_API_KEY=

# LLM provider: anthropic | openai
QF_LLM_PROVIDER=anthropic

# ── API server ────────────────────────────────────────────────────────────────
# Optional API key — leave blank to disable auth
SDC_API_KEY=

SDC_HOST=0.0.0.0
SDC_PORT=8787
SDC_DEBUG=false

# Comma-separated list of allowed CORS origins
# SDC_ALLOWED_ORIGINS=https://myapp.fly.dev,http://localhost:5173
